# KDA Infrastructure Configuration
# All paths are relative to this file's directory (infra/)
# Source this file in scripts: source "$(dirname "$0")/../config.env"

# Project root (parent of infra/)
INFRA_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$INFRA_DIR")"

# SOL-ExecBench location (sibling of infra/)
SOL_ROOT="$PROJECT_ROOT/sol-execbench"
SOL_RUN_DATASET="$SOL_ROOT/scripts/run_dataset.py"

# Workspace and data paths
WORKSPACES_DIR="$INFRA_DIR/workspaces"
TEMPLATES_DIR="$INFRA_DIR/templates"
BASELINE_RESULTS_DIR="$INFRA_DIR/baseline-results"
ORCHESTRATOR_DIR="$INFRA_DIR/orchestrator"

# Role models
KDA_WORKER_MODEL="${KDA_WORKER_MODEL:-claude-opus-4-6[1m]}"

# GPU lock. Leave GPU_LOCK_FILE empty to derive a per-GPU lock from GPU UUID.
GPU_LOCK_DIR="${GPU_LOCK_DIR:-/tmp}"
GPU_LOCK_FILE="${GPU_LOCK_FILE:-}"
